{
  "name": "streamd",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vp dev\" \"wrangler pages dev public --port 8788 --d1 DB\"",
    "dev:mock": "VITE_USE_MOCK_SERVER=true vp dev",
    "build": "tsc -b && vp build",
    "lint": "vp lint .",
    "test": "vp test",
    "test:run": "vp test run",
    "start": "wrangler pages dev dist --d1=DB",
    "db:reset": "rm -rf .wrangler && npm run build && npm start",
    "prepare": "vp config"
  },
  "dependencies": {
    "idb": "^8.0.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@cloudflare/workers-types": "^4.20260405.1",
    "@eslint/js": "^9.39.4",
    "@rolldown/plugin-babel": "^0.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "msw": "^2.13.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest",
    "wrangler": "^4.80.0"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
  },
  "packageManager": "npm@11.12.1",
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
